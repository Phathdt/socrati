env: "development"

server:
  host: "localhost"
  port: 4000

logger:
  level: "debug"
  format: "text"

database:
  uri: "postgresql://postgres:postgres@localhost:5432/socrati?sslmode=disable"

embedder:
  provider: "voyage"
  model: "voyage-4-lite"
  base_url: "https://api.voyageai.com/v1"
  api_key: "" # set via VOYAGE_API_KEY or EMBEDDER__API_KEY
  timeout_ms: 5000
  max_retries: 3
  max_chars: 8000
